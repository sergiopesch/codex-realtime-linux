OPENAI_API_KEY=sk-...
# Optional: use a separate key for local Codex app-server auth.
CODEX_API_KEY=sk-...
# Or reuse OPENAI_API_KEY for Codex local execution in this app.
CODEX_USE_OPENAI_API_KEY=true
# Set true if you want to replace an existing ChatGPT Codex login for this app run.
CODEX_FORCE_API_KEY_AUTH=false
# Optional: absolute path or executable name for the Codex CLI.
CODEX_BIN=codex
# Optional: Codex task approval policy. Defaults to on-request; use never only for trusted non-interactive workspaces.
CODEX_APPROVAL_POLICY=on-request
# Optional: keep false unless you deliberately want the desktop voice route to run Codex inside this app source tree.
CODEX_ALLOW_APP_SOURCE_TASKS=false
# Optional: absolute path for the Node runtime used by the Electron app to start the API server. Blank or relative values are ignored.
CODEX_REALTIME_NODE_BIN=/absolute/path/to/node
# Optional: desktop renderer/API origin override. Must be a root http://localhost, http://127.0.0.1, or http://[::1] origin.
CODEX_DESKTOP_API_URL=
# Optional: timeout for Codex app-server RPC requests, from 1000 to 600000 ms.
CODEX_RPC_TIMEOUT_MS=120000
# Optional: timeout for upstream OpenAI/admin/rate HTTP requests, from 1000 to 120000 ms.
UPSTREAM_FETCH_TIMEOUT_MS=20000
# Optional: local smoke-test override for OpenAI API calls. Only https://api.openai.com or root loopback origins are accepted.
CODEX_REALTIME_OPENAI_API_BASE_URL=
# Optional: comma-separated extra trusted root loopback http origins for the localhost API.
CODEX_REALTIME_ALLOWED_ORIGINS=
# Optional: require this token as X-Codex-Local-Api-Token on privileged /api/* routes for manual API supervision.
CODEX_LOCAL_API_TOKEN=
# Optional: Express JSON request body limit for API routes, up to 25mb.
CODEX_REALTIME_JSON_LIMIT=25mb
# Optional: override persisted sidebar workspace/thread state location with an absolute path. Relative paths are ignored.
CODEX_REALTIME_STATE_PATH=/tmp/codex-realtime-linux/app-state.json
# Optional: override the local Settings-saved secret location with an absolute path. Relative paths are ignored.
CODEX_REALTIME_SECRETS_PATH=/tmp/codex-realtime-linux/secrets.json
# Optional: required for live organization projects/costs.
OPENAI_ADMIN_KEY=sk-admin-...
# Optional: pin USD -> GBP conversion for Usage. Must be positive and no higher than 10.
OPENAI_USAGE_GBP_RATE=0.79
# Optional: override the live USD -> GBP conversion endpoint.
OPENAI_USAGE_GBP_RATE_API=https://api.frankfurter.app/latest?from=USD&to=GBP
REALTIME_MODEL=gpt-realtime-2
# Optional realtime voice/persona overrides.
REALTIME_VOICE=cedar
REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Optional local context injected into Realtime instructions. Leave blank to avoid location context.
REALTIME_USER_NAME=
REALTIME_USER_LOCATION=
REALTIME_PERSONA=
# Optional OpenAI safety identifier override. Leave blank to use a stable anonymized per-install default.
OPENAI_SAFETY_IDENTIFIER=
# Optional: absolute path to arduino-cli. Blank or relative values are ignored.
ARDUINO_CLI_PATH=
ARDUINO_DEFAULT_FQBN=arduino:avr:uno
CODEX_MODEL=gpt-5.4
VISION_MODEL=gpt-5.4
