OPENAI_API_KEY=sk-...
# Optional: use a separate key for local Codex app-server auth.
CODEX_API_KEY=sk-...
# Or reuse OPENAI_API_KEY for Codex local execution in this demo.
CODEX_USE_OPENAI_API_KEY=true
# Set true if you want to replace an existing ChatGPT Codex login for this demo run.
CODEX_FORCE_API_KEY_AUTH=false
# Optional: required for live organization projects/costs.
OPENAI_ADMIN_KEY=sk-admin-...
REALTIME_MODEL=gpt-realtime-2
REALTIME_VOICE=marin
CODEX_MODEL=gpt-5.4
