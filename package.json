{
  "name": "codex-realtime-linux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n api,ui,electron -c cyan,green,magenta \"node server/index.mjs\" \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "dev:browser": "concurrently -n api,ui -c cyan,green \"node server/index.mjs\" \"vite --host 127.0.0.1\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:lan": "concurrently -k -n api,ui,electron -c cyan,green,magenta \"node server/index.mjs\" \"vite --host 0.0.0.0\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "dev:api": "node server/index.mjs",
    "desktop:app": "NODE_ENV=production electron electron/main.cjs",
    "electron": "electron electron/main.cjs",
    "install:desktop": "node scripts/install-desktop-entry.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test server/*.test.mjs",
    "smoke:degraded": "node scripts/smoke-degraded.mjs",
    "smoke:desktop": "node scripts/smoke-desktop-release.mjs",
    "smoke:renderer": "node scripts/smoke-renderer.mjs",
    "verify:live": "node scripts/probe-mvp-live-environment.mjs",
    "verify:manual": "node scripts/record-mvp-manual-checklist.mjs",
    "verify:mvp": "node scripts/check-mvp-readiness.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright-core": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "form-data": "^4.0.6"
  }
}
